{
  "name": "SemOps2 Dev Container",
  "build": {
    "context": "..",
    "dockerfile": "Dockerfile",
    "args": {
      "REQUIREMENTS_FILE": "requirements-devcontainer.txt"
    }
  },
  "workspaceFolder": "/workspace",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "zxh404.vscode-proto3",
        "ms-azuretools.vscode-docker"
      ]
    }
  },
  "postCreateCommand": "task buf:dep:update && task buf:generate",
  "remoteUser": "root"
}
